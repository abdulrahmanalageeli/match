# Twilio WhatsApp API
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_SENDER=whatsapp:+your_twilio_sender_number
# Approved template SIDs for Twilio WhatsApp templates (with quick reply buttons)
TWILIO_MATCH_TEMPLATE_SID=your_match_notification_template_sid
TWILIO_REMINDER_TEMPLATE_SID=your_event_reminder_template_sid
TWILIO_PAYMENT_TEMPLATE_SID=your_payment_reminder_template_sid
